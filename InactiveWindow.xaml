<Window x:Class="ScreenTimer.InactiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inaktivitet" Height="180" Width="260"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual">

    <Border x:Name="BlinkBorder" Background="Black" CornerRadius="13"
            BorderBrush="Red" BorderThickness="3">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="15">
            <TextBlock x:Name="BlinkText1" Text="ER DU DER?" FontWeight="Bold"
                       Foreground="White" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel Orientation="Vertical">

                <Button Command="{Binding ResumeFromInactivityCommand}"
                        Content="JEG ER HER!" Padding="10" FontWeight="Bold"
                        Background="#444" Foreground="White" Cursor="Hand"
                        Click="Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>

                <Grid Height="10"/>

                <Button Command="{Binding RollbackTimeCommand}"
                        Content="VAR HER IKKE (-15m)" Padding="10" FontWeight="Bold"
                        Background="#CC3333" Foreground="White" Cursor="Hand"
                        Click="Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>